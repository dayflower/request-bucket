{
  "name": "request-bucket",
  "private": true,
  "version": "0.8.0",
  "license": "MIT",
  "author": "dayflower",
  "repository": {
    "type": "git",
    "url": "https://github.com/dayflower/request-bucket.git"
  },
  "keywords": [],
  "homepage": "https://github.com/dayflower/request-bucket",
  "bugs": {
    "url": "https://github.com/dayflower/request-bucket/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "bun scripts/with-env.ts bun --hot server/index.ts",
    "start": "NODE_ENV=production bun server/index.ts",
    "build": "bun scripts/with-env.ts bun scripts/build.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "fix": "biome check --write .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opensearch-project/opensearch": "^3.5.1",
    "base-x": "^5.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "globals": "^17.5.0",
    "typescript": "~6.0.3"
  }
}
